APP_ENV=local
APP_NAME=mrchat-api
APP_VERSION=dev

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=15s

CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

POSTGRES_ENABLED=true
POSTGRES_DSN=
POSTGRES_AUTO_MIGRATE=true
POSTGRES_MIGRATIONS_DIR=db/migrations
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=mrchat
POSTGRES_PASSWORD=mrchat
POSTGRES_DB=mrchat
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=20
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=30m

REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=3s
REDIS_READ_TIMEOUT=2s
REDIS_WRITE_TIMEOUT=2s

JWT_SECRET=change-me
JWT_ISSUER=mrchat-api
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=168h
AUTH_REFRESH_COOKIE_NAME=mrchat_refresh_token
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_SECURE=false
